// global functions

int power(int base, int exponent) {
    if (exponent == 0) {
        return 1;
    } else {
        int result = base;
        for (int x=0; x<exponent; x++) {
            result *= base;
        }
        return result;
    }
    return 1;
}
bool within(vec2 a, vec2 b, vec2 fragCoord) {
    vec2 diff = (abs(a-b));
    vec2 mid_point = (a+b)/2.;
    vec2 relative_to_mid = abs(mid_point-fragCoord);
    if (relative_to_mid.x > diff.x/2. || relative_to_mid.y > diff.y/2.) {
        return false;
    } else {
        return true;
    }
    return false;
}